---
// src/layouts/Layout.astro
import { Image } from 'astro:assets';
import logo from '../assets/branding/logo.png';

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title} | JB Fueston</title>
  </head>
  <body>
    
    <nav class="navbar">
      <div class="nav-container">
        <a href="/" class="brand-container">
          <Image src={logo} alt="JB Logo" height={42} class="logo-img" />
          <div class="brand-text">
            <span class="name">JB Fueston</span>
            <span class="tagline">AEROSPACE ENGINEERING & SYSTEMS</span>
          </div>
        </a>
        
        <div class="nav-links">
          <a href="/academics">Academic Work</a>
          <a href="/lab-bench">The Lab Bench</a>
          <a href="/field-ops">Field Operations</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <slot /> 
    </main>

  </body>
</html>

<style is:global>
  /* --- GLOBAL CSS --- */
  :root {
    --bg-color: #f8f9fa;
    --text-main: #212529;
    --text-muted: #495057;
    --accent: #0056b3;
    --card-bg: #ffffff;
    --brand-dark: #0b3c5d; 
    --brand-light: #328cc1; 
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-main);
    line-height: 1.6;
  }

  /* --- NAVIGATION BASE CSS --- */
  .navbar { 
    background: var(--card-bg); 
    border-bottom: 1px solid #dee2e6; 
    padding: 0.75rem 0;
    width: 100%;
  }
  
  .nav-container { 
    max-width: 800px; 
    margin: 0 auto; 
    padding: 0 2rem; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  
  .brand-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    min-width: max-content;
  }

  .logo-img {
    width: auto;
    height: 42px;
    object-fit: contain;
    display: block;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-dark);
    line-height: 1.1;
    display: block;
  }

  .tagline {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--brand-light);
    margin-top: 0.15rem;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-links a { 
    margin-left: 1.5rem; 
    text-decoration: none; 
    color: var(--text-muted); 
    font-weight: 500; 
    font-size: 0.95rem; 
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  
  .nav-links a:hover { 
    color: var(--accent); 
  }

  /* --- LAYOUT CONTAINER --- */
  .container { 
    max-width: 800px; 
    margin: 0 auto; 
    padding: 3rem 2rem; 
  }
  
  /* Shared Elements */
  .divider { 
    border: 0; 
    height: 1px; 
    background: #dee2e6; 
    margin: 3rem 0; 
  }

  /* --- MOBILE BREAKPOINT METRICS --- */
  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;