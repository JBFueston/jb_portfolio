---
// src/layouts/Layout.astro
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <title>{title} | JB Fueston</title>
  </head>
  <body>
    
    <nav class="navbar">
      <div class="nav-container">
        <a href="/" class="brand-container">
          <img src="/favicon.png" alt="JB Logo Icon" class="nav-favicon-img" />
          <div class="brand-text">
            <span class="name">JB Fueston</span>
            <span class="tagline">AEROSPACE ENGINEERING & SYSTEMS</span>
          </div>
        </a>
        
        <div class="nav-links">
          <a href="/academics">Academic Work</a>
          <a href="/lab-bench">The Lab Bench</a>
          <a href="/field-ops">Field Operations</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <slot /> 
    </main>

  </body>
</html>

<style is:global>
  /* --- GLOBAL DESIGN SYSTEM TOKENS --- */
  :root {
    --bg-color: #f8f9fa;
    --text-main: #212529;
    --text-muted: #495057;
    --accent: #0056b3;
    --card-bg: #ffffff;
    --brand-dark: #0b3c5d; 
    --brand-light: #328cc1; 
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-main);
    line-height: 1.6;
  }

  /* --- NAVIGATION BASE DESKTOP CSS --- */
  .navbar { 
    background: var(--card-bg); 
    border-bottom: 1px solid #dee2e6; 
    padding: 0.75rem 0;
    width: 100%;
  }
  
  .nav-container { 
    max-width: 800px; 
    margin: 0 auto; 
    padding: 0 2rem; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  
  .brand-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  /* Fixed size allocation for the miniature circle logo mark */
  .nav-favicon-img {
    width: 50px !important;
    height: 50px !important;
    max-width: 50px;
    max-height: 50px;
    object-fit: contain;
    flex-shrink: 0;
    display: block;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-dark);
    line-height: 1.1;
    display: block;
  }

  .tagline {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--brand-light);
    margin-top: 0.15rem;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-links a { 
    margin-left: 1.5rem; 
    text-decoration: none; 
    color: var(--text-muted); 
    font-weight: 500; 
    font-size: 0.95rem; 
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  
  .nav-links a:hover { 
    color: var(--accent); 
  }

  /* --- LAYOUT CONTAINER --- */
  .container { 
    max-width: 800px; 
    margin: 0 auto; 
    padding: 3rem 2rem; 
  }
  
  .divider { 
    border: 0; 
    height: 1px; 
    background: #dee2e6; 
    margin: 3rem 0; 
  }

  /* --- MOBILE BREAKPOINT METRICS (MAX-WIDTH: 768px) --- */
  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column; 
      justify-content: center;
      align-items: center;
      gap: 1rem;
      padding: 0.5rem 1rem;
    }

    .brand-container {
      justify-content: center;
      width: 100%;
    }

    .name {
      font-size: 1.15rem;
      text-align: left;
    }
    
    .tagline {
      font-size: 0.55rem;
      text-align: left;
    }

    .nav-links {
      width: 100%;
      justify-content: center; 
      padding: 0;
      margin: 0;
    }

    .nav-links a {
      margin: 0 0.6rem !important; 
      font-size: 0.85rem;
    }
    
    .container {
      padding: 2rem 1.1rem; 
    }
  }
</style>